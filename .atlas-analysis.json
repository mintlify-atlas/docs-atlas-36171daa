  "keyFeatures": [
    "TypeScript client library for ATProto and Bluesky",
    "OAuth-based authentication and session management",
    "Lexicon schema definition language",
    "DID and handle resolution",
    "Cryptographic signing and verification",
    "Repository data structures with MST",
    "XRPC HTTP API client and server",
    "Personal Data Server (PDS) implementation",
    "Bluesky AppView implementation",
    "Rich text parsing and rendering",
    "Content moderation system"
  ],
